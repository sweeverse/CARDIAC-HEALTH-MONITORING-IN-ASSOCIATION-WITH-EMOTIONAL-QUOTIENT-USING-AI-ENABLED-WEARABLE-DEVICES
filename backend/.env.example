# Copy this file to .env and fill in real values. Never commit .env.

# MongoDB Atlas connection string (yours, with the real password — NOT <password>)
# Example: mongodb+srv://swee28:REAL_PASSWORD_HERE@cluster0.6ukkdvi.mongodb.net/?appName=Cluster0
MONGODB_URI=mongodb+srv://USERNAME:REAL_PASSWORD_HERE@cluster0.6ukkdvi.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=CardioEQ

# Generate a real random secret for production, e.g.: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Allowed frontend origin(s) for CORS, comma-separated
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: enables the AI health assistant to use Claude instead of the
# built-in template responses. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: real air-quality data for environmental correlation (e.g. OpenWeatherMap, AirVisual)
AIR_QUALITY_API_KEY=

# Optional: enables the AI health assistant chatbot via Gemini instead of
# the built-in template responses.
GROQ_API_KEY=
